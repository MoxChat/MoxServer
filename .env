# MoxServer default environment for direct binary deployment.
# Copy this file and replace database credentials before running in production.

MOXSERVER_ADDR=:8980
MOXSERVER_DB_DSN=postgres://moxserver:change-me@127.0.0.1:5432/moxserver?sslmode=disable

# Optional database bootstrap. Keep disabled unless the DSN below has admin privileges.
MOXSERVER_DB_AUTO_INIT=0
MOXSERVER_DB_SUPER_DSN=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
MOXSERVER_DB_NAME=moxserver
MOXSERVER_DB_USER=moxserver
MOXSERVER_DB_PASSWORD=change-me

MOXSERVER_DATA_RETENTION_DAYS=30
MOXSERVER_CHALLENGE_TTL_SECONDS=60
MOXSERVER_AUTH_FAIL_WINDOW_MINUTES=30
MOXSERVER_AUTH_FAIL_BAN_MINUTES=30
MOXSERVER_AUTH_FAIL_BAN_THRESHOLD=10
